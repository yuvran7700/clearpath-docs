{
  "openapi": "3.0.3",
  "info": {
    "title": "ClearPath API - Production",
    "description": "API for retrieving preprocessed weather data and transport disruption alerts.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://nv2ymlpynf.execute-api.us-east-1.amazonaws.com",
      "description": "Production"
    }
  ],
  "paths": {
    "/weather/collection": {
      "get": {
        "summary": "Get ADAGE weather data for a given date",
        "description": "Returns ADAGE-formatted weather JSON file from S3 for a given date.",
        "operationId": "getWeatherAdage",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "The date to retrieve ADAGE weather data for, in YYYY-MM-DD format.",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-02-18"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with raw ADAGE weather data.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ADAGEWeatherRecord" },
                "example": {
                    "data_source": "BOM",
                    "dataset_type": "Daily weather observations",
                    "dataset_id": "s3://clearpath-weather-index-v1/weather_collected/2026-03-18.json",
                    "events": [
                        {
                            "event_type": "Daily weather observations",
                            "event_time": {
                                "time_stamp": "2026-03-18T09:00:00",
                                "duration": 86400,
                                "duration_unit": "seconds",
                                "time_zone": "Australia/Sydney"
                            },
                            "event_attributes": {
                                "date": "2026-03-18",
                                "tempMin_C": 19.6,
                                "tempMax_C": 23.3,
                                "rainfall_mm": 55.0,
                                "evaporation_mm": "Unavailable",
                                "sunshineHours_hours": "Unavailable",
                                "windWindDir": "S",
                                "maxWindSpeed_kmh": 41.0,
                                "maxWindTime": "00:59",
                                "9am": {
                                    "temp_C": 20.3,
                                    "humidity_percent": 91.0,
                                    "cloudAmount_oktas": 7.0,
                                    "windDirection": "SSW",
                                    "windSpeed_kmh": 19.0,
                                    "mslp_hPa": 1022.0
                                },
                                "3pm": {
                                    "temp_C": 22.7,
                                    "humidity_percent": 81.0,
                                    "cloudAmount_oktas": 7.0,
                                    "windDirection": "S",
                                    "windSpeed_kmh": 15.0,
                                    "mslp_hPa": 1020.1
                                }
                            }
                        }
                    ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing or invalid date parameter.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "missing_date": {
                    "summary": "Missing date parameter",
                    "value": { "error": "Missing date parameter" }
                  },
                  "invalid_date": {
                    "summary": "Invalid date format",
                    "value": { "error": "Invalid date format" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "No ADAGE record found for the given date.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "Record not found" }
              }
            }
          }
        }
      }
    },
    "/weather/preprocessed": {
      "get": {
        "summary": "Get preprocessed weather data",
        "description": "Returns preprocessed weather data for a given date, including temperature, rainfall, sunshine, wind, and humidity classifications.",
        "operationId": "getWeatherPreprocessed",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "The date to retrieve weather data for, in YYYY-MM-DD format.",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-02-18"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with preprocessed weather data.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WeatherRecord" },
                "example": {
                  "data_source": "ClearPath",
                  "dataset_type": "Weather observations and severity",
                  "dataset_id": "dynamodb://clearpath-weather-data/2026-03-18",
                  "events": [
                      {
                          "event_type": "Weather observations and severity",
                          "event_time": {
                              "time_stamp": "2026-03-18T09:00:00",
                              "duration": 86400,
                              "duration_unit": "seconds",
                              "time_zone": "Australia/Sydney"
                          },
                          "event_attributes": {
                              "date": "2026-03-18",
                              "tempMin_C": 19.6,
                              "tempMax_C": 23.3,
                              "rainfall_mm": 55.0,
                              "sunshineHours_hours": "Unavailable",
                              "maxWindSpeed_kmh": 41.0,
                              "9am": {
                                  "temp_C": 20.3,
                                  "humidity_percent": 91.0
                              },
                              "3pm": {
                                  "temp_C": 22.7,
                                  "humidity_percent": 81.0
                              },
                              "weatherSeverity": {
                                  "sunSeverity": "N/A",
                                  "rainSeverity": "Heavy rain",
                                  "tempSeverity": "Mild",
                                  "windSeverity": "Windy",
                                  "humiditySeverity": "Extreme Humidity"
                              }
                          }
                      }
                  ]
              }
              }
            }
          },
          "400": {
            "description": "Bad request — missing or invalid date parameter.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "missing_date": {
                    "summary": "Missing date parameter",
                    "value": { "error": "Missing date parameter" }
                  },
                  "invalid_date": {
                    "summary": "Invalid date format",
                    "value": { "error": "Invalid date format" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "No weather record found for the given date.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "Record not found" }
              }
            }
          }
        }
      }
    },
    "/alert/collection": {
      "get": {
        "summary": "Get transport disruption tweets",
        "description": "Retrieves historical tweets from a specified Twitter account within a date range and returns them as an ADAGE-formatted dataset.",
        "operationId": "getAlertCollection",
        "parameters": [
          {
            "name": "base_query",
            "in": "query",
            "required": true,
            "description": "Twitter account filter. Must include a 'from:' prefix e.g. from:T1SydneyTrains.",
            "schema": {
              "type": "string",
              "example": "from:T1SydneyTrains"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "description": "Start date for tweet retrieval in YYYY-MM-DD format.",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-01"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "description": "End date for tweet retrieval in YYYY-MM-DD format.",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-02"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with ADAGE-formatted tweet dataset.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ADAGETweetDataset" },
                "example": {
                  "data_source": "Twitter",
                  "dataset_type": "Historical Tweets",
                  "dataset_id": "twitter:2026-03-01:2026-03-23:1234567890",
                  "time_object": {
                    "timestamp": "2026-03-23 12:00:00",
                    "timezone": "UTC"
                  },
                  "events": [
                    {
                      "time_object": {
                        "timestamp": "2026-03-23",
                        "duration": 0,
                        "duration_unit": "second",
                        "timezone": "UTC"
                      },
                      "event_type": "transport disruption tweet",
                      "attribute": {
                        "account_name": "T1 Sydney Trains",
                        "text": "Allow extra travel time due to an incident at Hornsby.",
                        "date": "2026-03-23"
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request — missing, invalid, or malformed parameters.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "missing_params": {
                    "summary": "Missing required parameters",
                    "value": { "message": "base_query, start_date, and end_date are required" }
                  },
                  "missing_from": {
                    "summary": "Missing from: filter in base_query",
                    "value": { "message": "base_query must include a 'from:account' filter e.g. from:T1SydneyTrains" }
                  },
                  "invalid_date": {
                    "summary": "Invalid date format",
                    "value": { "message": "Dates must be in YYYY-MM-DD format" }
                  },
                  "invalid_range": {
                    "summary": "start_date is after end_date",
                    "value": { "message": "start_date must be earlier than or equal to end_date" }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable — Lambda timeout due to large date range or Twitter API unavailability.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "message": "Service Unavailable" }
              }
            }
          }
        }
      }
    }
  },
