},
      "ADAGETweetDataset": {
        "type": "object",
        "properties": {
          "data_source": { "type": "string" },
          "dataset_type": { "type": "string" },
          "dataset_id": { "type": "string" },
          "time_object": { "type": "object", "properties": { "timestamp": { "type": "string" }, "timezone": { "type": "string" } } },
          "events": {
